NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx

# Microsoft 365 SSO — set to 1 once the Supabase Azure provider is configured
NEXT_PUBLIC_MICROSOFT_SSO=

# Linkus (Yeastar P-Series) click-to-call — server-side
NEXT_PUBLIC_LINKUS=
YEASTAR_API_URL=https://your-pbx-domain/openapi/v1.0
YEASTAR_CLIENT_ID=
YEASTAR_CLIENT_SECRET=

# Nextel WhatsApp Business API — server-side
# Full send_template endpoint including the account token path segment
NEXTEL_API_URL=https://api.nextel.io/API_V2/Whatsapp/send_template/XXXXXXXX
NEXTEL_API_KEY=
NEXTEL_TEMPLATE_ID=parent_connect
